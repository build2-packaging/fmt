# Configuration Variables

#
#
config [bool] config.fmt.module_only ?= false
config [bool] config.fmt.disable_import_std ?= false

# C++ Configuration
#
cxx.std = latest

using cxx

hxx{*}: extension = h
ixx{*}: extension = cc
cxx{*}: extension = cc
mxx{*}: extension = cc

# The test target for cross-testing (running tests under Wine, etc).
#
test.target = $cxx.target
