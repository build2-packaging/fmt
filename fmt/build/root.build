# Configuration Variables

# Disable access to `lib{fmt}`'s headers to encapsulate
# all entities in {fmt}'s C++ module with module linkage.
#
config [bool] config.fmt.module_only ?= false

# C++ Configuration
#
cxx.std = latest

using cxx

hxx{*}: extension = h
ixx{*}: extension = cc
cxx{*}: extension = cc
mxx{*}: extension = cc

# The test target for cross-testing (running tests under Wine, etc).
#
test.target = $cxx.target
